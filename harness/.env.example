# ── Neo4j (local Homebrew Neo4j, Community single-DB = tenant boundary) ──────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── Business / tenant root ───────────────────────────────────────────────────
KG_BUSINESS_ID=rare-seeds

# ── Agent auth (M2+) ─────────────────────────────────────────────────────────
# The ingestion engine uses your existing Claude Code CLI subscription login
# automatically (read from the macOS Keychain by the CLI the SDK drives).
# Leave the token UNSET for local dev. Only set it for headless/CI machines
# with no interactive login (generate via: claude setup-token).
# IMPORTANT: keep ANTHROPIC_API_KEY UNSET — if present it overrides the
# subscription and bills the API instead of your plan.
# CLAUDE_CODE_OAUTH_TOKEN=
