{"proposal_id": "kgp_c6e0b066151e", "operation": "upsert_edge", "target_label": "Metric", "target_id": "metric:executive:new_customers", "key_field": "metric_uid", "source_kind": "curated_rule", "source_ref": "acquisition_to_retention", "source_confidence": 0.5, "review_state": "applied", "dashboard_id": "causal-curated", "payload": {"type": "INFLUENCES", "from_label": "Metric", "from_id": "metric:executive:new_customers", "to_label": "Metric", "to_id": "metric:executive:retention_rate", "properties": {"mechanism": "Newly acquired customers form the cohorts whose later repeat-purchase behavior defines the retention rate, so the volume and acquisition quality of new customers (e.g., discount-driven vs. organic) shifts how many of them return and thus moves the measured retention rate.", "temporal_lag": "P30D", "direction": "source_to_target", "rule_id": "acquisition_to_retention", "prior_confidence": 0.5, "relation": "curated_rule", "confidence": 0.6, "evidence_mass": 1.0, "scoring_policy": "curated_prior_v1", "review": true, "deterministic": false, "review_state": "proposed", "source_kind": "curated_rule", "created_by": "curated_rule", "source_ref": "acquisition_to_retention", "source_confidence": 0.5}}, "reviewed_at": "2026-06-23T11:53:16.274834+00:00"}
{"proposal_id": "kgp_bd39b162c8e9", "operation": "upsert_edge", "target_label": "Metric", "target_id": "metric:executive:new_customers", "key_field": "metric_uid", "source_kind": "curated_rule", "source_ref": "acquisition_to_retention", "source_confidence": 0.5, "review_state": "applied", "dashboard_id": "causal-curated", "payload": {"type": "INFLUENCES", "from_label": "Metric", "from_id": "metric:executive:new_customers", "to_label": "Metric", "to_id": "metric:executive:returning_customers", "properties": {"mechanism": "A customer must first place a first order (becoming a new customer) before they can place a subsequent order, so today's pool of new customers becomes the source population that later converts into returning customers when they repurchase.", "temporal_lag": "P30D", "direction": "source_to_target", "rule_id": "acquisition_to_retention", "prior_confidence": 0.5, "relation": "curated_rule", "confidence": 0.6, "evidence_mass": 1.0, "scoring_policy": "curated_prior_v1", "review": true, "deterministic": false, "review_state": "proposed", "source_kind": "curated_rule", "created_by": "curated_rule", "source_ref": "acquisition_to_retention", "source_confidence": 0.5}}, "reviewed_at": "2026-06-23T11:53:16.274837+00:00"}
