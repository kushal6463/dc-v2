# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Env / secrets
.env
harness/.env
*.local

# Data outputs (keep the dirs, ignore the generated contents)
data/events/*.jsonl
data/proposals/*.json
data/runs/*
!data/**/.gitkeep

# Frontend — app/kg-canvas is its OWN git repo (versioned separately); the parent
# repo ignores it to avoid a dangling submodule gitlink.
app/kg-canvas/
app/node_modules/
app/dist/
app/.vite/
**/node_modules/
**/dist/
**/.vite/

# Generated build artifacts (regenerated by `kg build` / backup export)
data/backups/
data/build-report*.json
data/skeleton/

# OS
.DS_Store
