# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Env / secrets
.env
harness/.env
*.local

# Data outputs (keep the dirs, ignore the generated contents)
data/events/*.jsonl
data/proposals/*.json
data/runs/*
!data/**/.gitkeep

# Frontend (app/kg-canvas) — source IS tracked in this monorepo; only the heavy
# build artifacts and the disabled inner git history are excluded.
**/node_modules/
**/dist/
**/.vite/
app/kg-canvas/.git.disabled/

# Generated build artifacts (regenerated by `kg build` / backup export)
data/backups/
data/build-report*.json
data/skeleton/

# OS
.DS_Store

# Env examples / templates (excluded per request — no example files)
.env.example
*.env.example

# Regenerable edge outputs (deterministic + discovery pipelines; not used by the LLM build)
data/discovered_edges*.csv
data/candidate_edges*.csv
data/compositional_edges*.csv
data/crossproduct_edges*.csv
data/model_edges*.csv
data/structural_edges*.csv
